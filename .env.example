# =====================================================================
# Copy this file to ".env" and fill in the values. This is the ONLY file
# you need to edit to deploy the bot — nothing else requires manual changes.
# =====================================================================

# --- Docker isolation -------------------------------------------------
# Unique name for this stack on the host. All containers, the network and
# the volumes are prefixed with it, so several bots can share one server
# without clashing. Use a short, unique slug per bot.
COMPOSE_PROJECT_NAME=predlozhka

# --- Telegram ---------------------------------------------------------
# Bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Target channel (the bot must be an admin there)
CHANNEL_ID=-1001234567890

# Group/chat where moderation cards are posted
ADMIN_CHAT_ID=-1009876543210

# Chat for error notifications (can be the same as ADMIN_CHAT_ID)
ERROR_CHAT_ID=-1001111111111

# Comma-separated Telegram user IDs allowed to moderate.
# Get your ID from @userinfobot. Example: ADMIN_IDS=111111111,222222222
ADMIN_IDS=

# --- Database (PostgreSQL) -------------------------------------------
# DB_HOST is set automatically by docker-compose to the "postgres" service.
# Override it only if you point the bot at an external database.
DB_HOST=postgres
DB_NAME=tg_bot
DB_USER=bot_user
DB_PASSWORD=change_me_strong_password

# --- Redis ------------------------------------------------------------
# REDIS_HOST is set automatically by docker-compose to the "redis" service.
REDIS_HOST=redis
REDIS_PASSWORD=change_me_redis_password

# --- Optional ---------------------------------------------------------
# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
